#!/bin/sh
#CMSSDT_DAS_CLIENT_SIGN:12345678901234567890ABCDEFABCDEF
#Do not change the above magic line. It is signature for the cmssw ibs das_client wrapper
function get_parent_cmds ()
{
  local DEPTH=$2
  let DEPTH=$DEPTH+1
  [ $DEPTH -gt 2 ] && return 0
  local XPID=$(ps -p $1 -o ppid= | sed 's| ||g;')
  [ "$XPID" = "" -o "$XPID" = "1" ] && return 0
  cat "/proc/$XPID/cmdline"
  echo ""
  cat "/proc/$XPID/cmdline" >> ${DAS_QUERY_DIR}/${QUERY_SHA_HASH}.info
  echo "" >> ${DAS_QUERY_DIR}/${QUERY_SHA_HASH}.info
  get_parent_cmds "$XPID" "$DEPTH"
}

CVMFS_CACHE="/cvmfs/cms-ib.cern.ch/jenkins-env/das_queries"
CMD_NAME=$(basename $0)
SCRIPT_DIR=$(dirname $0)
CMD_NAME="dasgoclient"
LIMIT_RESULTS="NO"
QUERY=
FORMAT="plain"
DAS_EX_OPTS=""
LIMIT=""
HELP=
for ((i=1; i<=$#; i++)); do
  next=$((i+1))
  case  ${!i} in
    --query=*|-query=*   ) QUERY=$(echo ${!i} | sed 's|.*query=||') ;;
    --query|-query       ) QUERY=${!next} ;;
    --format=*|-format=* ) FORMAT=$(echo ${!i} | sed 's|.*=||') ;;
    --format|-format     ) FORMAT=${!next} ;;
    --unique|-unique     ) DAS_EX_OPTS="${DAS_EX_OPTS} -unique" ;;
    --limit=*|-limit=*   ) LIMIT=$(echo ${!i} | sed 's|.*limit=||') ;;
    --limit|-limit       ) LIMIT=${!next} ;;
    -json                ) CMS_BOT_USE_DASGOCLIENT=true ;;
    -h|--help|-help      ) HELP=YES ;;
  esac
done
[ "${LIMIT}" == "0" ] && LIMIT=""
[ "${LIMIT}" != "" ]  &&      DAS_EX_OPTS="${DAS_EX_OPTS} --limit=${LIMIT}"
[ "${DAS_EX_OPTS}" != "" ] && DAS_EX_OPTS=" #DAS_EXTRA_OPTIONS# ${DAS_EX_OPTS}"

ORIG_DAS_CLIENT=""
for DAS_CLIENT in $(echo $PATH | tr ':' '\n' | grep -E -v '/CMSSW_[^/]*/(bin|src)' | sed "s|\$|/${CMD_NAME}|") ; do
 [ -e ${DAS_CLIENT} ] || continue
 if [ $(head -2 ${DAS_CLIENT} | grep -a 'CMSSDT_DAS_CLIENT_SIGN' | wc -l) -eq 0 ] ; then ORIG_DAS_CLIENT=${DAS_CLIENT}; break; fi
done

if [ "X${ORIG_DAS_CLIENT}" = "X" ] ; then
  echo "${CMD_NAME}: Command not found." 1>&2
  exit 1
fi

if [ "${CMS_BOT_USE_DASGOCLIENT}" = "true" ] ; then
  ${ORIG_DAS_CLIENT} "$@"
  exit $?
fi

if [ "${QUERY}" = "" -o "${HELP}" != "" ] ; then
  ${ORIG_DAS_CLIENT} "$@"
  exit $?
fi
DOWNLOAD_CMD="curl -f -L -s"
case $(cmsos) in
  slc6_*|el6_* ) DOWNLOAD_CMD="wget -q -O -" ;;
  * ) ;;
esac
QUERY=$(echo "${QUERY}" | sed 's|^ *||;s| *$||;s|  *| |g;s| =|=|g;s|= |=|g;')
QUERY_SHA_HASH=$(echo -n "${QUERY}${DAS_EX_OPTS}" | sha256sum | sed 's| .*$||;s| *||')
QUERY_SHA=$(echo "${QUERY_SHA_HASH}" | sed 's|^\(..\)|\1/\1|')
QUERY_URL="https://raw.githubusercontent.com/cms-sw/cms-sw.github.io/master/das_queries/${QUERY_SHA}"
DAS_QUERY_DIR=das_query/$$
ENABLE_DEBUG=true
if [ "X${LOCALRT}" != "X" ] ; then DAS_QUERY_DIR="${LOCALRT}/${DAS_QUERY_DIR}" ; fi
rm -rf ${DAS_QUERY_DIR}
mkdir -p ${DAS_QUERY_DIR}
echo "${QUERY}${DAS_EX_OPTS}" > ${DAS_QUERY_DIR}/${QUERY_SHA_HASH}.query
touch ${DAS_QUERY_DIR}/${QUERY_SHA_HASH}.info
debug_log="${DAS_QUERY_DIR}/${QUERY_SHA_HASH}.debug"
out_log="${DAS_QUERY_DIR}/${QUERY_SHA_HASH}.out"
touch ${debug_log}
if [ "${FORMAT}" = "json" ]  ; then
  if [ -e "${CVMFS_CACHE}/${QUERY_SHA}.json" ] ; then
    echo "Using cache from ${CVMFS_CACHE}/${QUERY_SHA}.json" >> ${debug_log}
    QUERY_RESULTS=$(cat "${CVMFS_CACHE}/${QUERY_SHA}.json")
  else
    echo "Using cache from ${QUERY_URL}.json" >> ${debug_log}
    QUERY_RESULTS=$(${DOWNLOAD_CMD} "${QUERY_URL}.json" || true)
  fi
  if [ "${QUERY_RESULTS}" = "" ] ; then
    echo "No results found in github cache for ${QUERY_URL}.json" >> ${debug_log}
    sleep 1
    ${ORIG_DAS_CLIENT} "$@" > ${out_log}
    if grep -q 'failed to parse X509 proxy' ${out_log} ; then
      ENABLE_DEBUG=true
    fi
  else
    echo "OK: github cache found for ${QUERY_URL}.json" >> ${debug_log}
    echo "${QUERY_RESULTS}" > ${out_log}
  fi
else
  if [ -e "${CVMFS_CACHE}/${QUERY_SHA}" ] ; then
    echo "Using cache from ${CVMFS_CACHE}/${QUERY_SHA}" >> ${debug_log}
    QUERY_RESULTS=$(cat "${CVMFS_CACHE}/${QUERY_SHA}")
  else
    echo "Using cache from ${QUERY_URL}" >> ${debug_log}
    QUERY_RESULTS=$((${DOWNLOAD_CMD} "${QUERY_URL}" || true) | sed 's|\s*$||g;s|"||g')
  fi
  if [ "${QUERY_RESULTS}" = "" ] ; then
    echo "No results found in github cache for ${QUERY_URL}" >> ${debug_log}
    sleep 1
    ${ORIG_DAS_CLIENT} "$@" > ${out_log}
    if grep -q 'failed to parse X509 proxy' ${out_log} ; then
      ENABLE_DEBUG=true
    fi
  else
    echo "OK: github cache found for ${QUERY_URL}" >> ${debug_log}
    echo "${QUERY_RESULTS}" > ${out_log}
  fi
  if [ $(echo "${QUERY_RESULTS}" | grep /store/ |wc -l) -gt 0 ] ; then
    [ $((get_parent_cmds $$ 0 2>&1 || true) | grep -a '/cmsDriver.py\|/runTheMatrix.py' | wc -l) -gt 0 ] && LIMIT_RESULTS="YES"
  fi
fi
echo "LIMIT_RESULT=$LIMIT_RESULT" >> ${debug_log}
if [ "$LIMIT_RESULTS" = "YES" ] ; then
  cat ${out_log} | ${SCRIPT_DIR}/ibeos-lfn-sort > ${DAS_QUERY_DIR}/${QUERY_SHA_HASH}.selected
  cat ${DAS_QUERY_DIR}/${QUERY_SHA_HASH}.selected
else
  cat ${out_log}
fi
cat ${out_log} >> ${debug_log}
if ! $ENABLE_DEBUG ; then
  rm -f ${debug_log} ${out_log} ${DAS_QUERY_DIR}/${QUERY_SHA_HASH}.selected ${DAS_QUERY_DIR}/${QUERY_SHA_HASH}.info >/dev/null 2>&1 || true
else
  echo "============ DEBUG ========" >> ${debug_log}
  echo "============ ENV   ========" >> ${debug_log}
  env >> ${debug_log}
  echo "============ VOMS  ========" >> ${debug_log}
  voms-proxy-info >> ${debug_log} || true
  if [ "${X509_USER_PROXY}" != "" ] ; then
    ls -l "${X509_USER_PROXY}" >> ${debug_log} || true
  fi
fi
